{
  "name": "claude-code-headless",
  "version": "0.1.0",
  "description": "Programmatically control Claude Code through a headless terminal — structured JSON events, automated commands, async streaming API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc && cp src/testing/proxy-testing/mitmAddon.py dist/testing/proxy-testing/mitmAddon.py",
    "test": "tsx src/testing/verify.ts",
    "record": "tsx src/testing/record.ts",
    "replay": "tsx src/testing/replay.ts",
    "proxy-test": "tsx src/testing/proxy-testing/run.ts",
    "proxy-test-bootstrap": "tsx src/testing/proxy-testing/bootstrap.ts"
  },
  "dependencies": {
    "@xterm/headless": "^5.5.0",
    "chokidar": "^5.0.0"
  },
  "peerDependencies": {
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.21.0"
  },
  "license": "MIT"
}
