{
  "name": "claude-code-headless",
  "version": "0.1.0",
  "description": "Programmatically control Claude Code through a headless terminal — structured JSON events, automated commands, async streaming API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && cp src/proxy/mitmAddon.py dist/proxy/mitmAddon.py",
    "upstream:check": "node scripts/check-upstream.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@xterm/headless": "^5.5.0",
    "chokidar": "^5.0.0"
  },
  "peerDependencies": {
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10"
  },
  "license": "MIT"
}
